{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pico Debug (Managed OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "executable": "${workspaceRoot}/build/demo_project.elf",
            "device": "RP2040",
            "gdbPath": "gdb-multiarch",
            "cwd": "${workspaceRoot}",
            "svdFile": "${env:PICO_SDK_PATH}/src/rp2040/hardware_regs/rp2040.svd",
            "configFiles": [
                    "board/pico-debug.cfg"
            ],
            "openOCDLaunchCommands": [
                "adapter speed 4000"
            ],
            "runToMain": true,
            "postRestartCommands": [
                "break main",
                "continue"
            ]
        }
    ]
}